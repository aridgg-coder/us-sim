# MATLAB and TUSX Configuration for US Simulator Backend
#
# Copy this file to .env and fill in the values for your environment.
# The backend will auto-detect MATLAB if it's on PATH, but you can override with MATLAB_ROOT.

# ============================================================================
# MATLAB Configuration
# ============================================================================

# Optional: Path to MATLAB installation root
# If not set, the system will search common locations and PATH
# Example Linux:    /usr/local/MATLAB/R2023b
# Example Windows:  /mnt/c/Program Files/MATLAB/R2023b
# Example macOS:    /Applications/MATLAB_R2023b.app
MATLAB_ROOT=

# ============================================================================
# TUSX Configuration
# ============================================================================

# Path to TUSX toolbox on the MATLAB path
# If TUSX is cloned into this repo at tusx/, this is usually not needed
# (the launcher will add it automatically)
TUSX_PATH=./tusx

# Path to k-Wave toolbox on the MATLAB path
# If k-Wave is installed system-wide, leave blank for auto-detection
KWAVE_PATH=

# ============================================================================
# Simulation Configuration
# ============================================================================

# Maximum simulation runtime in seconds (default: 300 = 5 minutes)
SIMULATION_TIMEOUT=300

# Force stub mode (no MATLAB) for testing
# Use "--use-stub" flag in run_tusx_wrapper.py to override
USE_STUB_MODE=false

# ============================================================================
# Database Configuration
# ============================================================================

DATABASE_URL=postgresql://postgres:password@localhost/us_simulator

# ============================================================================
# API Configuration
# ============================================================================

# API Host
API_HOST=0.0.0.0

# API Port
API_PORT=8000

# Max simulation workers
API_WORKERS=4
